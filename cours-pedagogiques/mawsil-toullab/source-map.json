      "audio_spans": [
        {"lesson_id": "009-09", "start_seconds": 0.5, "end_seconds": 3204.96, "evidence": "الخبر والحال ومقول القول والعطف وروابط الحال الماضية بقد وواو الحال."},
        {"lesson_id": "010-10", "start_seconds": 0.8, "end_seconds": 916.66, "evidence": "زيادتا الجملة المستثناة والواقعة مبتدأ مع إبقاء الخلاف وعدم تحويلهما إلى إجماع."}
      ],
      "canonical_refs": ["livres/shamela/mawsil-toullab/matn/6973/book.md", "livres/pdf/mawsil-toullab/matn/mawsil-toullab.pdf"],
