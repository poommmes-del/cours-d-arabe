      "estimated_study_minutes": 20,
      "audio_spans": [
        {"lesson_id": "006-06", "start_seconds": 1.6, "end_seconds": 1845.47, "evidence": "تشبيه عناية المصنف بالطبيب، حذف فعل الشرط، أن وأي التفسيريتان، وجناس عنوان الكتاب."},
        {"lesson_id": "007-07", "start_seconds": 570, "end_seconds": 1709.53, "evidence": "السجع والجناس ودلالة المن ثم انحصار فوائد الكتاب في الأبواب الأربعة؛ حذفت المقدمة العقدية الجانبية."}
      ],
